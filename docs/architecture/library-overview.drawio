        <mxCell id="e_hook2_main" value="gates Edit / Write" style="endArrow=classic;html=1;exitX=0;exitY=0.5;entryX=0.5;entryY=1;strokeColor=#b85450;fontSize=10;fontStyle=1" edge="1" parent="1" source="hook2" target="mainAgent">
