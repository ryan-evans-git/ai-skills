        <mxCell id="e_subagent_main" value="summary back" style="endArrow=classic;html=1;exitX=0;exitY=0.75;entryX=1;entryY=0.75;strokeColor=#9673a6;fontSize=10;dashed=1" edge="1" parent="1" source="subagent" target="mainAgent">
          <mxGeometry relative="1" as="geometry" />
