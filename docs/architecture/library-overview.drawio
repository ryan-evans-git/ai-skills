        <mxCell id="e_main_subagent" value="Agent tool" style="endArrow=classic;html=1;exitX=1;exitY=0.75;entryX=0;entryY=0.25;strokeColor=#9673a6;fontSize=10;fontStyle=1" edge="1" parent="1" source="mainAgent" target="subagent">
          <mxGeometry relative="1" as="geometry" />
