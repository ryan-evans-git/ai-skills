        <mxCell id="e_subagent_skills" style="endArrow=classic;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#666666;dashed=1" edge="1" parent="1" source="subagent" target="subagentSkills">
          <mxGeometry relative="1" as="geometry" />
