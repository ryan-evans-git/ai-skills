        <mxCell id="e_hook1_md" value="regenerates managed section" style="endArrow=classic;html=1;exitX=0.5;exitY=0;entryX=0.5;entryY=1;strokeColor=#b85450;fontSize=10;fontStyle=1" edge="1" parent="1" source="hook1" target="claudeMd">
