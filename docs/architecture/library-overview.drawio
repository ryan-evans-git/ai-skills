<mxfile host="app.diagrams.net" modified="2026-05-15T00:00:00.000Z" agent="ai-skills/docs/architecture/library-overview.drawio" version="24.0.0">
  <diagram id="ai-skills-overview" name="ai-skills overview">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="ai-skills — how the pieces fit together" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1320" height="30" as="geometry" />
        </mxCell>

        <mxCell id="user" value="User" style="shape=mxgraph.basic.actor;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="60" y="320" width="60" height="80" as="geometry" />
        </mxCell>

        <mxCell id="mainAgent" value="Main Claude agent&#xa;&#xa;(your active session)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=13;verticalAlign=top;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="240" y="300" width="220" height="120" as="geometry" />
        </mxCell>

        <mxCell id="claudeMd" value="CLAUDE.md&#xa;&#xa;Always-loaded house rules.&#xa;Hand-written + managed-section&#xa;regenerated at session start." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;verticalAlign=top;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="240" y="100" width="220" height="120" as="geometry" />
        </mxCell>

        <mxCell id="skills" value="Skills library&#xa;~/.claude/skills/&#xa;&#xa;~85 playbooks · 16 categories&#xa;Auto-triggered when the description&#xa;matches the user's request.&#xa;&#xa;In-thread — share the main&#xa;agent's context window." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edda;strokeColor=#2e8540;fontSize=12;verticalAlign=top;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="560" y="100" width="280" height="180" as="geometry" />
        </mxCell>

        <mxCell id="subagent" value="Subagent&#xa;~/.claude/agents/&#xa;&#xa;8 specialist roles&#xa;Spawned via the Agent tool.&#xa;&#xa;Fresh context window.&#xa;Scoped tools per agent.&#xa;Returns one summary message." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;verticalAlign=top;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="560" y="340" width="280" height="180" as="geometry" />
        </mxCell>

        <mxCell id="subagentSkills" value="Subagent reads&#xa;the same Skills&#xa;as its playbooks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#666666;fontSize=11;dashed=1" vertex="1" parent="1">
          <mxGeometry x="920" y="380" width="160" height="100" as="geometry" />
        </mxCell>

        <mxCell id="hooksGroup" value="Hooks .claude/settings.json&#xa;&#xa;Run by the harness, not by Claude." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;verticalAlign=top;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="240" y="560" width="600" height="200" as="geometry" />
        </mxCell>

        <mxCell id="hook1" value="SessionStart&#xa;refresh_claude_md.py&#xa;&#xa;Refreshes (or creates) CLAUDE.md&#xa;managed section every session.&#xa;Auto-creates in git repos when missing." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=11;verticalAlign=top;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="260" y="620" width="260" height="120" as="geometry" />
        </mxCell>

        <mxCell id="hook2" value="PreToolUse: Edit | Write | NotebookEdit&#xa;require_plan.py &amp; require_failing_test.py&#xa;&#xa;Block edits when no plan exists in&#xa;docs/plans/CURRENT.md or when no&#xa;recent test file accompanies prod code.&#xa;Bypass: env var per hook." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=11;verticalAlign=top;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="540" y="620" width="280" height="120" as="geometry" />
        </mxCell>

        <mxCell id="install" value="install.sh symlinks:&#xa;skills/&lt;cat&gt;/&lt;name&gt;/ → ~/.claude/skills/&lt;name&gt;/&#xa;agents/&lt;name&gt;.md → ~/.claude/agents/&lt;name&gt;.md&#xa;(or .claude/&lt;skills|agents&gt;/ for project install)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;verticalAlign=top;spacingTop=8;spacingLeft=12" vertex="1" parent="1">
          <mxGeometry x="920" y="100" width="380" height="100" as="geometry" />
        </mxCell>

        <mxCell id="legend" value="Color legend:&#xa;Green = active agent&#xa;Yellow = always-loaded context&#xa;Bright green = skills (description-triggered)&#xa;Purple = subagent (isolated context)&#xa;Red = harness-enforced hooks" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;align=left;verticalAlign=top;spacingTop=8;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="920" y="560" width="380" height="120" as="geometry" />
        </mxCell>

        <mxCell id="e_user_main" style="endArrow=classic;startArrow=classic;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#333333;" edge="1" parent="1" source="user" target="mainAgent">
          <mxGeometry relative="1" as="geometry" />
