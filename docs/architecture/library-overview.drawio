        <mxCell id="e_subskills_skills" value="same library" style="endArrow=classic;html=1;exitX=0.5;exitY=0;entryX=0.5;entryY=1;strokeColor=#666666;dashed=1;fontSize=10" edge="1" parent="1" source="subagentSkills" target="skills">
          <mxGeometry relative="1" as="geometry" />
