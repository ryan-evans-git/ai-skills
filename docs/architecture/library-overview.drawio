        <mxCell id="e_main_skills" value="description match" style="endArrow=classic;html=1;exitX=1;exitY=0.25;entryX=0;entryY=1;strokeColor=#2e8540;fontSize=10" edge="1" parent="1" source="mainAgent" target="skills">
