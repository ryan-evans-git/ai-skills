        <mxCell id="e_md_main" value="loaded into context" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#d6b656;fontSize=10" edge="1" parent="1" source="claudeMd" target="mainAgent">
